|---------------------------------------------------------|
| // problem -- 4                                         |
| // print mirror image of right angle triangle           |
|---------------------------------------------------------|


#include<iostream>
using namespace std;
int main(){
    int i,j;
    int n;

    cout<<"enter the value of n-- ";
     cin >> n;
// number of times to print the pattern 

// outer loop 
for(int i=1;i<=n;i++){
    // cout<<" ";
    // innner loop 
     for(int j=n-i;j>=1;j--){
         cout<<" ";
    }
    for (int k = 1; k<=i; k++){
         cout<<"*";
    }
    cout<<"\n";
}
return 0;
}




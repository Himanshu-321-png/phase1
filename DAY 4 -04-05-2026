// problem -- 1 
// print 1 to 10,10 number of times

#include<iostream>
using namespace std;
int main(){
    int i,j;
// number of times to print the pattrern |

// outer loop 
for(int i=1;i<=10;i++){
    for(int j=1;j<=10;j++){
        cout<<j<<" ";
    }
    cout<<"\n";
}
return 0;
}


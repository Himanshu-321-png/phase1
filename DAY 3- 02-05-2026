// Problem 2 -- 
// Print 10 to 1 using a for loop 
#include <iostream>
using namespace std;

int main() {
    for(int i = 10; i >= 1; i--){
        cout << i << " ";
    }
    return 0;
}


  // problem 3 
     // using while loop ;
#include <iostream>
using namespace std;

int main(){
     
    int i=1;
    while(i<=10){
        cout<<i<<" ";
        i++;
    }
    return 0;
}


  // problem 4 
     // using while loop ; // reverse

#include <iostream>
using namespace std;

int main(){
     
    int i=10;
    while(i>=1){
        cout<<i<<" ";
        i--;
    }
    return 0;
}


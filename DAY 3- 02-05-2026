|   // problem 9                                      |
|   // using loops ; print  prime number or not       |
|-----------------------------------------------------|


#include <iostream>
using namespace std;

int main(){
    int n;
    cin>>n;
    bool isPrime = true;
    
    
    if(n<2){
    isPrime = false;
    }else{
        for(int i=2;i<n;i++){
            if(n%i==0){
            isPrime = false;
            break;
            }
        }
    }
    if(isPrime){
        cout<<"Prime number";

    }else{
        cout<<"not a prime number";
    }
    return 0;
}


#include <iostream>
using namespace std;
class vehicle {
    public:
    void start(){
        cout<<"vehicle is start"<<"\n";
    }
};
class car : public vehicle {
    public: 
    void drive (){
        cout<<"car is running "<<"\n";
    }
};
class bike : public vehicle {
    public:
    void drive(){
        cout<<"bike is running"<<"\n";
    }
};
int main() {
car obj1;
obj1.start();
obj1.drive();
bike obj2;
obj2.drive();

    return 0;
}


|          // TYPES OF POLYMORPHISM ----2.2        |
|          // FUNCTION OVERRDING                   |
|==================================================|

       #include <iostream>
          using namespace std;
        class animal{
            public:
            virtual void sound(){
                cout<<"animal makes sound"<<endl;
            }
        };
        class dog : public animal {
            public:
            void sound()  override {
            cout<<"dog makes sound"<<endl;
            }
        };
          class cat : public animal {
              public:
            void sound()  override {
            cout<<"cat makes sound"<<endl;
            }
        };
        int main(){
            dog d;
            cat c;;
            d.sound();
            c.sound();
        }





















#include <iostream>
using namespace std;
class vehicle {
    public:
    void start(){
        cout<<"vehicle is start"<<"\n";
    }
};
class car : public vehicle {
    public: 
    void drive (){
        cout<<"car is running "<<"\n";
    }
};
int main() {
    car obj1;
obj1.start();
obj1.drive();;

    return 0;
}


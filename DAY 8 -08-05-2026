        cout<<"vehicle is start"<<"\n";
    }
};
class car : public vehicle {
    public: 
    void drive (){
        cout<<"car is running "<<"\n";
    }
};
class speedometer : public car{
    public:
    void speed(){
        cout<<"cars speed is 100km/h"<<"\n";
    }
};
int main() {
speedometer obj1;
obj1.start();
obj1.drive();
obj1.speed();

    return 0;
}

